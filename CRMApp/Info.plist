<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <key>CFBundleName</key>
    <string>私域CRM</string>
    <key>CFBundleDisplayName</key>
    <string>私域 CRM</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourname.PrivateCRM</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIRequiredDeviceCapabilities</key>
    <array><string>armv7</string></array>
    <key>UISupportedInterfaceOrientations</key>
    <array><string>UIInterfaceOrientationPortrait</string></array>
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Face ID -->
    <key>NSFaceIDUsageDescription</key>
    <string>使用 Face ID 快速安全地解锁 CRM 数据</string>

    <!--
        微信「用其他App打开」修复：
        必须同时设置这两个 key，App 才会出现在系统分享/打开列表中。
        UIFileSharingEnabled  → 让 App 出现在「文件」App 和分享面板
        LSSupportsOpeningDocumentsInPlace → 允许就地打开文档（不复制）
    -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>

    <!-- 文档类型注册 -->
    <key>CFBundleDocumentTypes</key>
    <array>

        <dict>
            <key>CFBundleTypeName</key><string>Excel xlsx</string>
            <key>CFBundleTypeRole</key><string>Viewer</string>
            <key>LSHandlerRank</key><string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>org.openxmlformats.spreadsheetml.sheet</string>
                <string>com.microsoft.excel.xlsx</string>
            </array>
        </dict>

        <dict>
            <key>CFBundleTypeName</key><string>Excel xls</string>
            <key>CFBundleTypeRole</key><string>Viewer</string>
            <key>LSHandlerRank</key><string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.microsoft.excel.xls</string>
            </array>
        </dict>

        <dict>
            <key>CFBundleTypeName</key><string>CSV</string>
            <key>CFBundleTypeRole</key><string>Viewer</string>
            <key>LSHandlerRank</key><string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.comma-separated-values-text</string>
            </array>
        </dict>

        <!-- CRM 备份文件，Owner 级别，微信发来后本App优先打开 -->
        <dict>
            <key>CFBundleTypeName</key><string>CRM 备份</string>
            <key>CFBundleTypeRole</key><string>Editor</string>
            <key>LSHandlerRank</key><string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.yourname.crmbackup</string>
            </array>
        </dict>

        <!-- 兜底：接受所有数据文件，确保微信分享时能找到本App -->
        <dict>
            <key>CFBundleTypeName</key><string>通用数据文件</string>
            <key>CFBundleTypeRole</key><string>Viewer</string>
            <key>LSHandlerRank</key><string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.data</string>
                <string>public.content</string>
            </array>
        </dict>

    </array>

    <!-- 自定义 UTI 导出 -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key><string>com.yourname.crmbackup</string>
            <key>UTTypeDescription</key><string>CRM 加密备份</string>
            <key>UTTypeConformsTo</key>
            <array><string>public.data</string></array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>crmbackup</string></array>
                <key>public.mime-type</key>
                <string>application/octet-stream</string>
            </dict>
        </dict>
    </array>

</dict>
</plist>
