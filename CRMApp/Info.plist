<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- App 基础信息 -->
    <key>CFBundleName</key>
    <string>私域CRM</string>
    <key>CFBundleDisplayName</key>
    <string>私域 CRM</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourname.PrivateCRM</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Face ID 权限说明 -->
    <key>NSFaceIDUsageDescription</key>
    <string>使用 Face ID 快速安全地解锁 CRM 数据</string>

    <!--
        Bug 2 修复：注册文档类型，让微信/钉钉「用其他App打开」时能找到本App。
        必须同时注册 public.data / public.content 作为兜底，
        否则微信不会在分享列表中显示本App图标。
    -->
    <key>CFBundleDocumentTypes</key>
    <array>

        <!-- Excel xlsx -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Excel 工作表 (xlsx)</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>org.openxmlformats.spreadsheetml.sheet</string>
                <string>com.microsoft.excel.xlsx</string>
            </array>
        </dict>

        <!-- Excel xls -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Excel 工作表 (xls)</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.microsoft.excel.xls</string>
            </array>
        </dict>

        <!-- CSV -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>CSV 文件</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.comma-separated-values-text</string>
                <string>public.delimited-values-text</string>
            </array>
        </dict>

        <!-- CRM 加密备份文件（Owner 级别，微信发送后可用本App打开）-->
        <dict>
            <key>CFBundleTypeName</key>
            <string>CRM 加密备份</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.yourname.crmbackup</string>
                <string>public.data</string>
            </array>
        </dict>

        <!-- 兜底：接受所有文件（确保微信「用其他App打开」能显示本App）-->
        <dict>
            <key>CFBundleTypeName</key>
            <string>通用文件</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.content</string>
                <string>public.data</string>
            </array>
        </dict>

    </array>

    <!-- UTI 导出声明（自定义备份文件格式）-->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.yourname.crmbackup</string>
            <key>UTTypeDescription</key>
            <string>CRM 加密备份</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>crmbackup</string>
                </array>
                <key>public.mime-type</key>
                <string>application/octet-stream</string>
            </dict>
        </dict>
    </array>

</dict>
</plist>
